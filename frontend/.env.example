# Local dev: leave REACT_APP_API_URL empty to proxy /api and /ws to localhost:8080 via setupProxy.js
# Or set explicitly:
# REACT_APP_API_URL=http://localhost:8080
REACT_APP_API_URL=
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Native app builds (Capacitor): use frontend/.env.production.local instead:
# REACT_APP_API_URL=https://noqtrade.com
# REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
