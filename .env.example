# Database Secrets
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=<DB_NAME>
DB_HOST=<DB_HOST>
DB_PORT=<DB_PORT>

# Backend Secrets
JWT_SECRET=<JWT_SECRET>
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>

# Frontend Build Args (used by docker-compose frontend build)
REACT_APP_API_URL=<REACT_APP_API_URL>
REACT_APP_GOOGLE_CLIENT_ID=<REACT_APP_GOOGLE_CLIENT_ID>

# For local `npm start`, copy frontend/.env.example to frontend/.env.local
# and set REACT_APP_GOOGLE_CLIENT_ID. Leave REACT_APP_API_URL empty to proxy
# API calls to http://localhost:8080, or set REACT_APP_API_URL=http://localhost:8080